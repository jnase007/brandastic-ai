# ── Supabase ─────────────────────────────────────────────
# Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ── Calendly (booking modal) ─────────────────────────────
# Your scheduling link, e.g. https://calendly.com/legacy-ai/30min
VITE_CALENDLY_URL=https://calendly.com/your-link/30min

# ── Pitch video (optional) ───────────────────────────────
# An embeddable URL (YouTube/Vimeo embed). Leave blank to show the placeholder.
VITE_PITCH_VIDEO_URL=
